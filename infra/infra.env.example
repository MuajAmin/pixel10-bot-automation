# infra/.env.example — Copy to .env and fill in real values
# Usage: cp infra.env.example .env

# ── ReDroid Image (REQUIRED) ──
# Set to the image built by redroid-script, e.g.:
#   redroid/redroid:11.0.0_gapps_ndk_magisk_widevine
# Do NOT leave this as CHANGE_ME. docker-compose.yml requires GApps + Magisk + NDK.
REDROID_IMAGE=CHANGE_ME

# ── Worker API Key (REQUIRED) ──
# Change this to a strong, unique key (e.g. openssl rand -hex 32)
ANDROID_WORKER_API_KEY=CHANGE_ME

# ── Worker API Bind Address (optional) ──
# Default: 127.0.0.1 (localhost only — use SSH tunnel for remote access)
# Set to 0.0.0.0 to expose publicly (less secure, ensure API key is strong)
# WORKER_API_BIND=0.0.0.0
WORKER_API_BIND=127.0.0.1

# ── Proxy (optional) ──
# PROXY_URL=http://user:pass@proxy:port

# ── ProtonVPN (WireGuard) ──
# Download WireGuard config from:
#   https://account.protonvpn.com/downloads#wireguard-configuration
# Place the .conf file in infra/wireguard/wg0.conf
# Then run: sudo bash setup_protonvpn.sh ./wireguard/wg0.conf
# This routes ReDroid container traffic through VPN while keeping SSH direct.
PROTONVPN_ENABLED=true
